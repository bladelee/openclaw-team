# API 配置
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# 应用配置
NEXT_PUBLIC_APP_URL=http://localhost:3002

# 后端基础 URL (用于 OAuth 重定向，不包含 /api)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000

# Liuma 认证中心配置
# NEXT_PUBLIC_LIUMA_URL: Liuma认证中心地址
# - 生产环境: https://auth.liuma.app
# - 开发环境: 如果有本地部署的Liuma认证服务，配置本地地址
# - 默认值: https://auth.liuma.app
NEXT_PUBLIC_LIUMA_URL=https://auth.liuma.app

# NEXT_PUBLIC_APP_ID: 在Liuma认证中心注册的应用ID
# - 需要在Liuma认证中心提前注册应用
# - 默认值: openclaw-pc
# - 注册地址: https://auth.liuma.app
NEXT_PUBLIC_APP_ID=openclaw-pc

# Casdoor SSO 配置 (备用认证方式)
NEXT_PUBLIC_CASDOOR_ENABLED=false
NEXT_PUBLIC_CASDOOR_ENDPOINT=http://localhost:8000
