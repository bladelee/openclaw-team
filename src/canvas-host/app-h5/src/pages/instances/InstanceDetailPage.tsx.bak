/**
 * 实例详情页面 - 融合 Chat + Settings + Info
 * 使用 A2UI 深色主题设计规范
 * 颜色系统：
 *   - 背景: #071016 (深蓝黑)
 *   - 表面: #0f1720 (深色)
 *   - 卡片: #1e293b (深灰)
 *   - 主色: #06b6d4 (青色)
 *   - 边框: #1e293b / #334155
 *   - 文字: #ffffff (主), #94a3b8 (次), #64748b (辅)
 */

import { useState, useEffect } from "react";
import { useParams, useNavigate, Link } from "react-router-dom";
import {
  ArrowLeft,
  Settings as SettingsIcon,
  MoreHorizontal,
  RefreshCw,
  Play,
  Square,
  Trash2,
  Server,
} from "lucide-react";
import { getInstance, startInstance, stopInstance, deleteInstance, type Instance } from "../../services/api/tenant";
import { useI18n } from "../../contexts/I18nContext";

// 导入子组件
import { InstanceChat } from "./components/InstanceChat";
import { InstanceSettings } from "./components/InstanceSettings";
import { InstanceInfo } from "./components/InstanceInfo";

type ViewMode = "chat" | "settings" | "info";

export function InstanceDetailPage() {
  const { instanceId } = useParams<{ instanceId: string }>();
  const navigate = useNavigate();
  const { t } = useI18n();

  const [instance, setInstance] = useState<Instance | null>(null);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string | null>(null);
  const [actionLoading, setActionLoading] = useState<string | null>(null);
  const [viewMode, setViewMode] = useState<ViewMode>("chat");
  const [settingsOpen, setSettingsOpen] = useState(false);
  const [moreMenuOpen, setMoreMenuOpen] = useState(false);

  // 获取实例详情
  const fetchInstance = async () => {
    if (!instanceId) {
      return;
    }

    setLoading(true);
    setError(null);
    try {
      const data = await getInstance(instanceId);
      setInstance(data);
    } catch (err) {
      setError(err instanceof Error ? err.message : t("instances.error"));
    } finally {
      setLoading(false);
    }
  };

  // 刷新实例状态
  const refreshInstance = async () => {
    await fetchInstance();
  };

  // 启动实例
  const handleStart = async () => {
    if (!instanceId) {
      return;
    }
    setActionLoading("start");
    try {
      await startInstance(instanceId);
      await new Promise((resolve) => setTimeout(resolve, 1000));
      await refreshInstance();
    } catch (err) {
      setError(err instanceof Error ? err.message : t("instances.startError"));
    } finally {
      setActionLoading(null);
    }
  };

  // 停止实例
  const handleStop = async () => {
    if (!instanceId) {
      return;
    }
    setActionLoading("stop");
    try {
      await stopInstance(instanceId);
      await new Promise((resolve) => setTimeout(resolve, 1000));
      await refreshInstance();
    } catch (err) {
      setError(err instanceof Error ? err.message : t("instances.stopError"));
    } finally {
      setActionLoading(null);
    }
  };

  // 删除实例
  const handleDelete = async () => {
    if (!instanceId) {
      return;
    }
    if (!confirm(t("instances.confirmDelete"))) {
      return;
    }

    setActionLoading("delete");
    try {
      await deleteInstance(instanceId);
      navigate("/instances");
    } catch (err) {
      setError(err instanceof Error ? err.message : t("instances.deleteError"));
    } finally {
      setActionLoading(null);
    }
  };

  // 打开设置抽屉
  const openSettings = () => {
    setSettingsOpen(true);
  };

  // 关闭设置抽屉
  const closeSettings = () => {
    setSettingsOpen(false);
  };

  // 切换视图
  const switchView = (view: ViewMode) => {
    setViewMode(view);
    setMoreMenuOpen(false);
  };

  // 初始加载
  useEffect(() => {
    fetchInstance();

    // 设置定时刷新（每5秒）
    const interval = setInterval(fetchInstance, 5000);
    return () => clearInterval(interval);
  }, [instanceId]);

  // 监听打开设置事件（从 InstanceChat 组件触发）
  useEffect(() => {
    const handleOpenSettings = () => {
      openSettings();
    };

    window.addEventListener("open-instance-settings", handleOpenSettings);
    return () => {
      window.removeEventListener("open-instance-settings", handleOpenSettings);
    };
  }, []);

  // 加载状态
  if (loading) {
    return (
      <div className="flex items-center justify-center h-screen" style={{ backgroundColor: "#071016" }}>
        <div className="text-center">
          <div className="inline-block w-12 h-12 border-4 border-[#06b6d4] border-t-transparent rounded-full animate-spin mb-4" />
          <p className="text-[#94a3b8]">{t("instances.loading")}</p>
        </div>
      </div>
    );
  }

  // 错误状态
  if (error) {
    return (
      <div className="flex items-center justify-center h-screen p-4" style={{ backgroundColor: "#071016" }}>
        <div
          className="rounded-xl p-6"
          style={{
            maxWidth: 400,
            width: "100%",
            backgroundColor: "#0f1720",
            border: "1px solid #1e293b",
          }}
        >
          <div className="space-y-4">
            <p className="text-[#ef4444] font-semibold text-lg">错误</p>
            <p className="text-[#94a3b8]">{error}</p>
            <button
              onClick={refreshInstance}
              disabled={loading}
              className="w-full px-4 py-3 bg-[#06b6d4] text-white rounded-lg font-medium disabled:opacity-50 disabled:cursor-not-allowed active:scale-[0.98] transition-transform"
            >
              {t("instances.retry")}
            </button>
            <Link to="/instances">
              <button className="w-full px-4 py-3 bg-[#1e293b] text-white rounded-lg font-medium active:scale-[0.98] transition-transform">
                {t("instances.backToList")}
              </button>
            </Link>
          </div>
        </div>
      </div>
    );
  }

  // 实例不存在
  if (!instance) {
    return (
      <div className="flex items-center justify-center h-screen p-4" style={{ backgroundColor: "#071016" }}>
        <div
          className="rounded-xl p-6"
          style={{
            maxWidth: 400,
            width: "100%",
            backgroundColor: "#0f1720",
            border: "1px solid #1e293b",
          }}
        >
          <div className="text-center space-y-4">
            <Server className="w-16 h-16 mx-auto text-[#94a3b8]" />
            <p className="text-lg font-semibold text-white">实例不存在</p>
            <p className="text-[#94a3b8]">未找到该实例</p>
            <Link to="/instances">
              <button className="px-6 py-3 bg-[#06b6d4] text-white rounded-lg font-medium">
                {t("instances.backToList")}
              </button>
            </Link>
          </div>
        </div>
      </div>
    );
  }

  // 获取状态显示
  const getStatusDisplay = () => {
    const statusConfig = {
      running: { color: "#10b981", text: t("status.running"), icon: "●" },
      stopped: { color: "#94a3b8", text: t("status.stopped"), icon: "○" },
      starting: { color: "#f59e0b", text: t("status.starting"), icon: "◎" },
      stopping: { color: "#f59e0b", text: t("status.stopping"), icon: "◎" },
      error: { color: "#ef4444", text: t("status.error"), icon: "●" },
    };

    const config = statusConfig[instance.status] || statusConfig.stopped;
    return config;
  };

  const statusDisplay = getStatusDisplay();

  return (
    <div className="flex flex-col h-screen" style={{ backgroundColor: "#071016", color: "#ffffff" }}>
      {/* 顶部导航栏 - A2UI 深色主题 */}
      <header
        className="flex items-center justify-between px-4 py-3 flex-shrink-0"
        style={{ backgroundColor: "#0f1720", borderBottom: "1px solid #1e293b" }}
      >
        {/* 左侧：返回按钮 + 实例名称 */}
        <div className="flex items-center gap-3" style={{ flex: 1, minWidth: 0 }}>
          <Link to="/instances" className="text-[#94a3b8] hover:text-white transition-colors">
            <ArrowLeft className="w-5 h-5" />
          </Link>
          <div style={{ flex: 1, minWidth: 0 }}>
            <div className="flex items-center gap-2">
              <h1 className="text-lg font-semibold truncate m-0">{instance.name}</h1>
              <span
                className="w-2 h-2 rounded-full flex-shrink-0"
                style={{ backgroundColor: statusDisplay.color }}
              />
            </div>
            <p className="text-sm text-[#94a3b8] truncate">{statusDisplay.text}</p>
          </div>
        </div>

        {/* 右侧：操作按钮 */}
        <div className="flex items-center gap-2">
          {/* 刷新按钮 */}
          <button
            onClick={refreshInstance}
            disabled={loading}
            className="p-2 rounded-lg hover:bg-[#1e293b] disabled:opacity-50 disabled:cursor-not-allowed transition-colors"
            aria-label={t("instances.refresh")}
          >
            <RefreshCw className={`w-4 h-4 ${loading ? "animate-spin" : ""}`} />
          </button>

          {/* 设置按钮 */}
          <button
            onClick={openSettings}
            className="p-2 rounded-lg hover:bg-[#1e293b] transition-colors"
            aria-label="设置"
          >
            <SettingsIcon className="w-5 h-5" />
          </button>

          {/* 更多菜单 */}
          <div className="relative">
            <button
              onClick={() => setMoreMenuOpen(!moreMenuOpen)}
              className="p-2 rounded-lg hover:bg-[#1e293b] transition-colors"
              aria-label="更多"
            >
              <MoreHorizontal className="w-5 h-5" />
            </button>

            {moreMenuOpen && (
              <>
                <div
                  className="fixed inset-0 z-40"
                  onClick={() => setMoreMenuOpen(false)}
                />
                <div
                  className="absolute right-0 top-full mt-2 z-50 rounded-lg shadow-lg"
                  style={{
                    minWidth: 180,
                    backgroundColor: "#0f1720",
                    border: "1px solid #1e293b",
                  }}
                >
                  <div className="py-1">
                    <button
                      onClick={() => switchView("chat")}
                      className="w-full px-4 py-3 text-left hover:bg-[#1e293b] transition-colors flex items-center gap-2"
                    >
                      💬 {t("instances.chat")}
                    </button>
                    <button
                      onClick={() => {
                        openSettings();
                        setMoreMenuOpen(false);
                      }}
                      className="w-full px-4 py-3 text-left hover:bg-[#1e293b] transition-colors flex items-center gap-2"
                    >
                      ⚙️ {t("instances.settings")}
                    </button>
                    <button
                      onClick={() => switchView("info")}
                      className="w-full px-4 py-3 text-left hover:bg-[#1e293b] transition-colors flex items-center gap-2"
                    >
                      ℹ️ {t("instances.info")}
                    </button>
                    <div className="h-px my-1" style={{ backgroundColor: "#1e293b" }} />
                    {instance.status === "running" ? (
                      <button
                        onClick={handleStop}
                        disabled={actionLoading !== null}
                        className="w-full px-4 py-3 text-left hover:bg-[#1e293b] transition-colors flex items-center gap-2 text-[#ef4444] disabled:opacity-50"
                      >
                        <Square className="w-4 h-4" />
                        {t("instances.stop")}
                      </button>
                    ) : (
                      <button
                        onClick={handleStart}
                        disabled={actionLoading !== null}
                        className="w-full px-4 py-3 text-left hover:bg-[#1e293b] transition-colors flex items-center gap-2 text-[#10b981] disabled:opacity-50"
                      >
                        <Play className="w-4 h-4" />
                        {t("instances.start")}
                      </button>
                    )}
                    <button
                      onClick={handleDelete}
                      disabled={actionLoading !== null}
                      className="w-full px-4 py-3 text-left hover:bg-[#1e293b] transition-colors flex items-center gap-2 text-[#ef4444] disabled:opacity-50"
                    >
                      <Trash2 className="w-4 h-4" />
                      {t("instances.delete")}
                    </button>
                  </div>
                </div>
              </>
            )}
          </div>
        </div>
      </header>

      {/* 主内容区 - Chat 优先 */}
      <main className="flex-1 overflow-hidden">
        {viewMode === "chat" && <InstanceChat instance={instance} />}
        {viewMode === "info" && <InstanceInfo instance={instance} />}
      </main>

      {/* 设置抽屉 - Modal 形式 */}
      {settingsOpen && (
        <>
          <div
            className="fixed inset-0 z-40 bg-black bg-opacity-50"
            onClick={closeSettings}
          />
          <div className="fixed inset-x-0 bottom-0 z-50 rounded-t-2xl max-h-[90vh] overflow-y-auto" style={{ backgroundColor: "#0f1720" }}>
            <div className="sticky top-0 px-4 py-4 border-b flex items-center justify-between" style={{ backgroundColor: "#0f1720", borderColor: "#1e293b" }}>
              <div className="flex items-center gap-2">
                <SettingsIcon className="w-5 h-5" />
                <span className="font-semibold">{t("instances.settings")}</span>
              </div>
              <button
                onClick={closeSettings}
                className="p-2 rounded-lg hover:bg-[#1e293b] transition-colors"
              >
                ✕
              </button>
            </div>
            <div className="p-4">
              <InstanceSettings
                instance={instance}
                onClose={closeSettings}
                onRefresh={refreshInstance}
              />
            </div>
          </div>
        </>
      )}
    </div>
  );
}
